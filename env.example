# ─────────────────────────────────────────────────────────────
# M-Changia Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file to GitHub.
# ─────────────────────────────────────────────────────────────

# Flask
SECRET_KEY=replace-with-a-long-random-string
FLASK_DEBUG=False

# Database
# Leave as SQLite for local development.
# On Render, paste the PostgreSQL connection string they provide.
DATABASE_URL=sqlite:///mchangia.db

# ── Africa's Talking ──────────────────────────────────────────
# Sign up at: https://africastalking.com
# Go to: Settings → API Key
AT_USERNAME=your_at_sandbox_username
AT_API_KEY=your_at_api_key
AT_WHATSAPP_SENDER=+254700000000    # Your AT WhatsApp business number

# ── Safaricom Daraja ──────────────────────────────────────────
# Register at: https://developer.safaricom.co.ke
# Create an app to get consumer key + secret
# Use sandbox credentials while testing
DARAJA_CONSUMER_KEY=your_consumer_key_here
DARAJA_CONSUMER_SECRET=your_consumer_secret_here
DARAJA_SHORTCODE=174379             # Sandbox shortcode (replace in production)
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
DARAJA_ENV=sandbox                  # Change to: production when you go live

# ── App ───────────────────────────────────────────────────────
# Your Render deployment URL — needed for M-Pesa callback
BASE_URL=https://your-app-name.onrender.com

# Pricing
SERVICE_FEE_PER_ENTRY=5            # KES 5 per contribution logged
REPORT_FEE=100                     # KES 100 for PDF audit report
